# JivniCare — Environment Variables Template

# App Configuration
NEXT_PUBLIC_SITE_URL="https://www.jivnicare.com"
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jivnicare?schema=public"

# Cache & Rate Limiting (Upstash Redis) - Optional
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# SMS Gateway (2Factor.in)
TWOFACTOR_API_KEY="your-2factor-api-key"

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# PII Encryption Keys (32-byte key and secure secret)
ENCRYPTION_KEY="your-encryption-key-must-be-32-characters"
HMAC_SECRET_KEY="your-hmac-secret-key-for-deterministic-phone-hashing"

# Cloudflare Turnstile Configuration
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-cloudflare-turnstile-site-key"
TURNSTILE_SECRET_KEY="your-cloudflare-turnstile-secret-key"

# Sentry Monitoring Configuration
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Authentication (NextAuth.js with Google OAuth)
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# Analytics & Monitoring - Optional
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
CRON_SECRET="your-cron-secret-for-auto-expire-cron-jobs"
REVALIDATION_SECRET="your-on-demand-revalidation-secret"

# Admin Emergency Backup Settings - Optional
ADMIN_TOTP_SECRET="your-fallback-admin-totp-secret"

# Local Development / Testing (OTP Bypass)
NEXT_PUBLIC_ENABLE_TEST_OTP="true"
NEXT_PUBLIC_TEST_OTP_NUMBERS="9999999999,9999999991,9999999992"
NEXT_PUBLIC_TEST_OTP_CODE="123456"

