// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum MediaType {
  DOCTOR_PROFILE
  HOSPITAL_GALLERY
  LICENSE_DOCUMENT
}

enum VerificationStatus {
  DRAFT
  PENDING
  PENDING_VERIFICATION
  VERIFIED
  UPDATE_PENDING
  REJECTED
  SUSPENDED
}

enum ClinicStatus {
  AVAILABLE
  LIMITED_SLOTS
  SHORT_BREAK
  EMERGENCY_ONLY
  FULLY_BOOKED_AUTO
  CLINIC_CLOSED
}

enum TargetType {
  DOCTOR
  HOSPITAL
  USER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  DEAD
}

enum UpdateStatus {
  PENDING
  APPROVED
  REJECTED
}

model ModerationLog {
  id         String     @id @default(uuid()) @map("_id")
  adminId    String
  admin      User       @relation(fields: [adminId], references: [id])
  action     String
  targetType TargetType
  targetId   String
  reason     String?
  createdAt  DateTime   @default(now())
}

model Media {
  id        String    @id @default(uuid()) @map("_id")
  url       String
  publicId  String    @unique
  type      MediaType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model Clinic {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  city         String
  address      String
  bannerImageUrl String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  doctors      Doctor[]
}

model User {
  id          String   @id @default(uuid()) @map("_id")
  firebaseUid String?
  phone       String   @unique
  email       String?
  name        String?
  password    String?
  location    String?
  latitude    Float?
  longitude   Float?
  role        Role     @default(PATIENT)
  isVerified  Boolean  @default(false)
  verificationStatus VerificationStatus @default(DRAFT)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leadId String?      @unique
  lead   LeadCapture? @relation(fields: [leadId], references: [id])

  doctor                 Doctor?
  patientProfile         PatientProfile?
  media                  Media[]
  moderationLogs         ModerationLog[]
  notifications          Notification[]
  savedDoctors           SavedDoctor[]
  notificationPreference NotificationPreference?
  queueTokens            QueueToken[]
  reportsSubmitted       Report[]
}

model LeadCapture {
  id                String     @id @default(uuid()) @map("_id")
  phone             String     @unique
  name              String?
  city              String?
  roleInterest      Role?
  specialty         String?
  clinicName        String?
  source            String?
  lastStepCompleted String?
  status            LeadStatus @default(NEW)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user User?
}

model PatientProfile {
  id               String    @id @default(uuid()) @map("_id")
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName         String?
  dateOfBirth      DateTime?
  gender           String?
  bloodGroup       String?
  emergencyContact String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ProfileUpdateLog {
  id        String       @id @default(uuid()) @map("_id")
  doctorId  String
  doctor    Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  field     String
  oldValue  String?
  newValue  String
  status    UpdateStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([doctorId, status])
}

model Doctor {
  id                 String             @id @default(uuid()) @map("_id")
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // JivniCare V1 Fields
  jivnicareId                 String?  @unique  // JC-DR-000001
  name                        String
  phone                       String   @unique
  speciality                  String
  qualification               String
  experienceYears             Int      @default(0)
  lifetimePatientsDeclaration String?  // Doctor declared
  jivnicarePatientsServed     Int      @default(0)  // System calculated
  consultationFee             Int      @default(0)
  clinicId                    String?  @db.ObjectId
  clinic                      Clinic?  @relation(fields: [clinicId], references: [id])
  isVerified                  Boolean  @default(false)
  isOnline                    Boolean  @default(false)
  isEmergencySupported        Boolean            @default(false)
  verificationDocuments       String[]
  averageConsultationMinutes  Int                @default(10)
  dailyTokenLimit             Int                @default(50)
  isActive                    Boolean            @default(true)
  specializations             String[]           @default([])

  // Legacy/Internal Fields
  slug               String             @unique
  doctorCode         String?            @unique
  bio                String?
  experience         Int                @default(0)
  fee                Int                @default(0)
  district           String
  hospitalName       String
  verificationStatus VerificationStatus @default(DRAFT)
  emergencyAvailable Boolean            @default(false)
  profileImage       String?
  gender             String?
  languages          String[]           @default([])
  rating             Float              @default(0)

  specialtyIds String[]
  specialties  Specialty[]   @relation(fields: [specialtyIds], references: [id])
  keywordIds   String[]
  keywords     Keyword[]     @relation(fields: [keywordIds], references: [id])
  savedBy      SavedDoctor[]
  dailyQueues  DailyQueue[]

  // ── Phase 16: Doctor Control System ────────────────────────
  availableDays               String[] @default([]) 
  availableTimeSlots          Json? 
  maxAppointmentsPerDay       Int      @default(0) 
  isAcceptingAppointments     Boolean  @default(true)
  profileCompletionPercentage Int      @default(0)

  // ── Real-World Clinic Operations Extension ─────────────────
  medicalRegistrationNumber      String?            @unique
  medicalCouncil                 String?
  registrationYear               Int?
  govtIdentityReference          String?
  dateOfBirth                    DateTime?
  primarySpecialtyId             String?
  followUpFee                    Int      @default(0)
  averageConsultationTime        Int      @default(15) 
  treatmentFocus                 String[] @default([])
  commonSymptomsTreated          String[] @default([])
  certifications                 String[] @default([])
  education                      String?
  qualifications                 String? 
  onlineConsultationAvailable    Boolean  @default(false)
  emergencyConsultationAvailable Boolean  @default(false)

  // ── Geo-Intelligence & Real Address Architecture ───────────
  clinicName                     String?
  fullAddress                    String?
  landmark                       String?
  locality                       String?
  city                           String?
  state                          String?
  pincode                        String?
  latitude                       Float?
  longitude                      Float?

  weeklySchedule   WeeklySchedule?
  clinicOperations ClinicOperations?
  updateLogs       ProfileUpdateLog[]

  shortCode String?
  clinicImage String? 

  reviewCount        Int @default(0)
  totalConsultations Int @default(0)

  verifiedBadgeLabel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  operators          Operator[]

  @@index([district, verificationStatus])
  @@index([rating, verificationStatus])
  @@index([city, verificationStatus, isAcceptingAppointments])
  @@index([verificationStatus, isAcceptingAppointments, createdAt])
  @@index([specialtyIds])
}

model Specialty {
  id          String     @id @default(uuid()) @map("_id")
  name        String     @unique
  slug        String     @unique
  doctorIds   String[]
  doctors     Doctor[]   @relation(fields: [doctorIds], references: [id])
  hospitalIds String[]
  hospitals   Hospital[] @relation(fields: [hospitalIds], references: [id])
}

model Keyword {
  id          String     @id @default(uuid()) @map("_id")
  term        String     @unique
  doctorIds   String[]
  doctors     Doctor[]   @relation(fields: [doctorIds], references: [id])
  hospitalIds String[]
  hospitals   Hospital[] @relation(fields: [hospitalIds], references: [id])
}

model Hospital {
  id                 String             @id @default(uuid()) @map("_id")
  name               String
  slug               String             @unique
  description        String?
  district           String
  address            String
  phone              String
  hospitalType       String             @default("General")
  verificationStatus VerificationStatus @default(PENDING)
  emergencyAvailable Boolean            @default(false)
  ambulanceAvailable Boolean            @default(false)
  website            String?
  rating             Float              @default(0)
  images             String[]           @default([])

  specialtyIds String[]
  specialties  Specialty[] @relation(fields: [specialtyIds], references: [id])
  keywordIds   String[]
  keywords     Keyword[]   @relation(fields: [keywordIds], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([district])
  @@index([verificationStatus])
  @@index([emergencyAvailable])
}

model SearchAnalytics {
  id              String   @id @default(uuid()) @map("_id")
  query           String
  normalizedQuery String
  district        String?
  resultsCount    Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([district])
  @@index([normalizedQuery])
}

model ProfileAnalytics {
  id         String     @id @default(uuid()) @map("_id")
  targetType TargetType
  targetId   String
  action     String
  createdAt  DateTime   @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

model Report {
  id          String       @id @default(uuid()) @map("_id")
  reporterId  String
  reporter    User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetType  TargetType
  targetId    String 
  reason      String
  description String?
  status      ReportStatus @default(PENDING)
  adminNotes  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([targetType, targetId])
}

enum NotificationType {
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  VERIFICATION_SUSPENDED
  PROFILE_UPDATED
  ADMIN_ALERT
  MODERATION_PENDING
  PLATFORM_ALERT
  ENGAGEMENT_ALERT
}

model Notification {
  id        String           @id @default(uuid()) @map("_id")
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json? 
  createdAt DateTime         @default(now())
  readAt    DateTime?

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model SavedDoctor {
  id        String   @id @default(uuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, doctorId])
  @@index([userId])
}

model NotificationPreference {
  id              String   @id @default(uuid()) @map("_id")
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  smsEnabled      Boolean  @default(false)
  emailEnabled    Boolean  @default(true)
  pushEnabled     Boolean  @default(false)
  whatsappEnabled Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

enum QueueStatus {
  NOT_STARTED
  ACTIVE
  PAUSED
  FULL
  COMPLETED
}

enum TokenSource {
  ONLINE
  WALK_IN
}

enum TokenStatus {
  WAITING
  AWAITING_ARRIVAL
  PAYMENT_PENDING
  READY
  CALLED
  IN_CONSULTATION
  COMPLETED
  SKIPPED
  CANCELLED
  NO_SHOW
  EXPIRED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model DailyQueue {
  id                   String       @id @default(uuid()) @map("_id")
  doctorId             String
  doctor               Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinicId             String?      @db.ObjectId
  logicalDate          String       // YYYY-MM-DD
  currentTokenNumber   Int          @default(0)
  currentServingToken  Int          @default(0)
  dailyLimit           Int          @default(50)
  status               String       @default("OPEN") // OPEN, CLOSED, EMERGENCY_ONLY
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  tokens               QueueToken[]

  // Legacy/Internal Fields
  date               DateTime    @db.Date @default(now())
  queueStatus        QueueStatus @default(NOT_STARTED)
  maxCapacity        Int         @default(50)
  currentActiveToken Int         @default(0)
  issuedTokensCount  Int         @default(0)
  emergencyIssuedTokensCount Int @default(0)
  cancelledCount     Int         @default(0)
  noShowCount        Int         @default(0)

  @@unique([doctorId, logicalDate])
  @@unique([doctorId, date])
}

model QueueToken {
  id           String    @id @default(uuid()) @map("_id")
  queueId      String
  queue        DailyQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  tokenNumber  Int       
  patientId    String?   
  patient      User?     @relation(fields: [patientId], references: [id])
  walkInEntryId String?  
  walkInEntry   WalkInEntry? @relation(fields: [walkInEntryId], references: [id])
  patientPhone String
  patientName  String?
  tokenType    String    // ONLINE, WALKIN, EMERGENCY
  status       String    // BOOKED, READY, CALLED, IN_CONSULTATION, COMPLETED, NO_SHOW, EXPIRED, CANCELLED
  bookedAt     DateTime  @default(now())
  readyAt      DateTime?
  calledAt     DateTime?
  completedAt  DateTime?
  isWaitlist   Boolean   @default(false)

  // Legacy/Internal Fields
  source      TokenSource @default(ONLINE)
  tokenStatus TokenStatus @default(WAITING)
  priority    Int         @default(0)
  isEmergency Boolean     @default(false)
  updatedAt   DateTime    @updatedAt

  @@unique([queueId, tokenNumber])
}

model WalkInEntry {
  id          String   @id @default(uuid()) @map("_id")
  patientName String
  phoneNumber String?
  symptoms    String?
  age         Int?
  gender      Gender?
  isEmergency Boolean  @default(false)
  createdAt   DateTime @default(now())

  token QueueToken[]
}

model OtpToken {
  id        String   @id @default(uuid()) @map("_id")
  phone     String   @unique
  hashedOtp String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RateLimit {
  id        String   @id @default(uuid()) @map("_id")
  ip        String   @unique
  count     Int      @default(1)
  resetTime DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklySchedule {
  id        String   @id @default(uuid()) @map("_id")
  doctorId  String   @unique
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  monday    Json 
  tuesday   Json
  wednesday Json
  thursday  Json
  friday    Json
  saturday  Json
  sunday    Json
  updatedAt DateTime @updatedAt
}

model ClinicOperations {
  id                 String       @id @default(uuid()) @map("_id")
  doctorId           String       @unique
  doctor             Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  status             ClinicStatus @default(AVAILABLE)
  statusExpiresAt    DateTime?
  statusReason       String?
  isClosedToday      Boolean      @default(false)
  pauseOnlineBooking Boolean      @default(false)
  walkInLimit        Int          @default(10)
  onlineLimit        Int          @default(20)
  emergencySlots     Int          @default(2)
}

model SystemCounter {
  id    String @id @map("_id")
  count Int    @default(64000)
}

model Operator {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  doctorId  String   @db.ObjectId
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  name      String
  phone     String
  role      String   @default("Receptionist")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
